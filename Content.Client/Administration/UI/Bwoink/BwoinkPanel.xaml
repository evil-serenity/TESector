<BoxContainer
    xmlns="https://spacestation14.io"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Orientation="Vertical"
    HorizontalExpand="True">
    <!-- Triage shortcut bar. Hidden by default; only populated for the admin-side
         panel when a classified player message arrives. Zero cost when hidden. -->
    <PanelContainer Name="TriageBar" Access="Public" Visible="False">
        <BoxContainer Orientation="Horizontal" HorizontalExpand="True"
                      Margin="2 1 2 1" SeparationOverride="6">
            <RichTextLabel Name="TriageCategoryLabel" Access="Public"
                           VerticalAlignment="Center" />
            <Control HorizontalExpand="True" />
            <WrapContainer Name="TriageActionContainer" Access="Public"
                           SeparationOverride="4" CrossSeparationOverride="2" />
        </BoxContainer>
    </PanelContainer>
    <OutputPanel Name="TextOutput" VerticalExpand="true" />
    <RichTextLabel Name="TypingIndicator" Access="Public" />
    <HistoryLineEdit Name="SenderLineEdit" />
    <RichTextLabel Name="RelayedToDiscordLabel" Access="Public" Visible="False" />
</BoxContainer>
